{
  "name": "Snapcast",
  "version": "0.8.3",
  "image": "ghcr.io/evthefuture/snapcast",
  "init": false,
  "stage": "stable",
  "slug": "snapcast",
  "description": "Snapcast server and/or client hosted on Home Assistant",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "startup": "services",
  "boot": "auto",
  "url": "https://github.com/EvTheFuture/hassio-addon-repository/snapcast",
  "webui": "http://[HOST]:[PORT:1780]/",
  "ports": {
    "1780/tcp": 1780
  },
  "ports_description": {
    "1780/tcp": "Snapcast web interface (Snapweb)"
  },
  "audio": true,
  "ingress": false,
  "options": {
    "server": {
      "enable": true,
      "enable_web": true,
      "enable_stream_librespot": true,
      "librespot_name": "Spotify",
      "librespot_device_name": "Snapcast",
      "librespot_initial_volume": 100,
      "librespot_bitrate": 320,
      "librespot_normalize": false,
      "librespot_killall": false,
      "librespot_disable_audio_cache": false,
      "librespot_params": "",
      "librespot_extra_params": "",
      "enable_stream_airplay": true,
      "airplay_name": "AirPlay",
      "airplay_device_name": "Snapcast",
      "airplay_ignore_volume_control": true,
      "airplay_port": 5000
    },
    "client": {
      "enable": false,
      "host": "127.0.0.1",
      "extra_params": ""
    }
  },
  "schema": {
    "server": {
      "enable": "bool",
      "enable_web": "bool",
      "enable_stream_librespot": "bool",
      "librespot_name": "str?",
      "librespot_device_name": "str?",
      "librespot_initial_volume": "int(0,100)?",
      "librespot_bitrate": "list(96|160|320)?",
      "librespot_normalize": "bool?",
      "librespot_killall": "bool?",
      "librespot_disable_audio_cache": "bool?",
      "librespot_params": "str?",
      "librespot_extra_params": "str?",
      "enable_stream_airplay": "bool",
      "airplay_name": "str?",
      "airplay_device_name": "str?",
      "airplay_ignore_volume_control": "bool",
      "airplay_default_volume": "float?",
      "airplay_port": "port?",
      "custom_streams": "str?"
    },
    "client": {
      "enable": "bool",
      "host": "str",
      "port": "port?",
      "extra_params": "str?"
    }
  },
  "host_network": true
}
